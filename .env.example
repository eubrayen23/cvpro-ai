# ────── APIs de IA (OBRIGATÓRIO) ──────────────────────────────────────────
# IMPORTANTE: estas chaves são usadas APENAS no servidor (Netlify Function),
# por isso NÃO têm o prefixo VITE_ e nunca são incluídas no bundle do frontend.
# Em produção, define-as nas variáveis de ambiente do Netlify.
# Em desenvolvimento, usa `netlify dev` para que a função tenha acesso a elas.

# Gemini: https://aistudio.google.com → Get API Key (GRÁTIS)
GEMINI_API_KEY=AIzaSy_COLOCA_AQUI_A_TUA_CHAVE

# Groq: https://console.groq.com → Create API Key (GRÁTIS)
GROQ_API_KEY=gsk_COLOCA_AQUI_A_TUA_CHAVE

# ────── Supabase (OBRIGATÓRIO) ────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ────── App ───────────────────────────────────────────────────────────────
VITE_APP_NAME=CVPro AI
VITE_APP_URL=http://localhost:5173
